  },
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/platform-express": "^11.1.16",
    "@repo/services": "workspace:*",
    "@repo/analytics": "workspace:*",
    "@trpc/server": "^11.11.0",
    "express": "^5.1.0",
    "ioredis": "^5.6.1",
    "superjson": "^2.2.6",
    "trpc-ui": "^1.0.15",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.0.2",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "uuid": "^11.1.0"
  }
