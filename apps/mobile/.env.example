# ============================================================
# Mobile (Expo) — zmienne środowiskowe
# Skopiuj do .env i uzupełnij wartości
# NIE commituj .env do repozytorium
# Zmienne z prefixem EXPO_PUBLIC_ są dostępne w kodzie aplikacji
# ============================================================

# ── Backend API ──────────────────────────────────────────────
# URL endpointu tRPC backendu
# Urządzenie fizyczne: użyj IP komputera zamiast localhost (np. http://192.168.1.100:3001/trpc)
# Emulator Android: http://10.0.2.2:3001/trpc
# Symulator iOS: http://localhost:3001/trpc
EXPO_PUBLIC_TRPC_URL=http://localhost:3001/trpc

# ── PostHog Analytics ────────────────────────────────────────
# Klucz API PostHog (pobierz z Project Settings > Project API Key)
# https://app.posthog.com lub https://eu.posthog.com
EXPO_PUBLIC_POSTHOG_KEY=your_posthog_key_here

# Host PostHog: https://app.posthog.com (US) lub https://eu.posthog.com (EU)
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com
