# Example environment variables for the backend
# Copy this file to .env and fill in your actual values

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_db_password # <-- CHANGE THIS
DB_DATABASE=turbo_template_db

# JWT Authentication
JWT_SECRET=your-super-secret-key-minimum-32-characters-long # <-- CHANGE THIS (min 32 chars)
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Redis Configuration
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_HOST=localhost

# PostHog analytics
# Get your API key from PostHog (https://app.posthog.com or https://eu.posthog.com)
# Go to Project Settings > Project API Key
POSTHOG_API_KEY=your_posthog_api_key_here

# Superadmin credentials (comma separated list of emails)
SUPERADMIN_EMAILS=superadmin@example.com
