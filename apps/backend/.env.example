# Backend environment variables

NODE_ENV=development
PORT=3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=app

# JWT Authentication
JWT_SECRET=replace-with-strong-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Web app (used for email links)
WEB_APP_URL=http://localhost:3000

# Redis
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
USE_REDIS_CACHING=true

# PostHog
POSTHOG_API_KEY=your_posthog_key_here
POSTHOG_HOST=https://app.posthog.com

# SMTP (optional, but required to send emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=notifications@example.com
SMTP_SECURE=false
