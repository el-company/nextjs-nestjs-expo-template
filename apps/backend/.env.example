# ============================================================
# Backend — zmienne środowiskowe
# Skopiuj do .env i uzupełnij wartości
# NIE commituj .env do repozytorium
# ============================================================

# ── Ogólne ──────────────────────────────────────────────────
# Środowisko uruchomienia: development | production | test
NODE_ENV=development

# Port serwera NestJS (domyślnie 3001)
PORT=3001

# ── Baza danych (PostgreSQL) ─────────────────────────────────
# Adres hosta PostgreSQL (Docker: localhost, produkcja: np. RDS endpoint)
DB_HOST=localhost

# Port PostgreSQL (domyślnie 5432)
DB_PORT=5432

# Nazwa użytkownika bazy danych
DB_USERNAME=postgres

# Hasło użytkownika bazy danych
DB_PASSWORD=postgres

# Nazwa bazy danych
DB_DATABASE=app

# ── JWT — Autentykacja ───────────────────────────────────────
# Sekret do podpisywania access tokenów (min. 32 znaki, np. openssl rand -hex 32)
JWT_SECRET=replace-with-strong-secret-min-32-chars

# Sekret do podpisywania refresh tokenów (inny niż JWT_SECRET!)
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret-min-32-chars

# Czas ważności access tokenu (format: 15m, 1h, 1d)
JWT_ACCESS_EXPIRATION=15m

# Czas ważności refresh tokenu (format: 7d, 30d)
JWT_REFRESH_EXPIRATION=7d

# ── Web App URL ──────────────────────────────────────────────
# URL aplikacji webowej — używany do generowania linków w mailach
# (np. link do weryfikacji email, reset hasła)
WEB_APP_URL=http://localhost:3000

# ── Superadmin ───────────────────────────────────────────────
# Lista adresów email z rolą superadmin (oddzielone przecinkami)
# Rola przypisywana automatycznie przy rejestracji lub seedzie
SUPERADMIN_EMAILS=superadmin@example.com

# ── Redis ────────────────────────────────────────────────────
# Pełny URL Redis (jeśli podany, nadpisuje REDIS_HOST/PORT/PASSWORD)
# Przykład: redis://:password@localhost:6379
REDIS_URL=

# Adres hosta Redis (używany gdy REDIS_URL nie jest ustawiony)
REDIS_HOST=localhost

# Port Redis (domyślnie 6379)
REDIS_PORT=6379

# Hasło Redis (opcjonalne, zostaw puste jeśli brak hasła)
REDIS_PASSWORD=

# Czy włączyć Redis caching (true/false)
# Wyłącz tylko do debugowania — w produkcji zawsze true
USE_REDIS_CACHING=true

# ── PostHog Analytics ────────────────────────────────────────
# Klucz API PostHog (pobierz z Project Settings > Project API Key)
# https://app.posthog.com lub https://eu.posthog.com
POSTHOG_API_KEY=your_posthog_key_here

# Host PostHog: https://app.posthog.com (US) lub https://eu.posthog.com (EU)
POSTHOG_HOST=https://app.posthog.com

# ── Email ────────────────────────────────────────────────────
# Provider emaili: resend | smtp
# - resend: wymaga RESEND_API_KEY (zalecany dla nowych projektów)
# - smtp: wymaga SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASSWORD
EMAIL_PROVIDER=resend

# ── Resend (zalecany provider) ───────────────────────────────
# Klucz API Resend (pobierz z https://resend.com → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Adres nadawcy maili (musi być zweryfikowana domena w Resend)
RESEND_FROM=noreply@yourdomain.com

# [TYLKO DEV] Przekieruj WSZYSTKIE maile wychodzące na ten adres
# Przydatne gdy free plan Resend pozwala wysyłać tylko na własny email
DEV_EMAIL_REDIRECT=

# ── SMTP (alternatywny provider) ─────────────────────────────
# Host serwera SMTP (np. smtp.gmail.com, smtp.mailgun.org)
SMTP_HOST=

# Port SMTP: 587 (STARTTLS), 465 (SSL), 25 (bez szyfrowania)
SMTP_PORT=587

# Użytkownik SMTP (zazwyczaj adres email)
SMTP_USER=

# Hasło SMTP
SMTP_PASSWORD=

# Adres nadawcy dla SMTP
SMTP_FROM=notifications@example.com

# Czy używać SSL/TLS (true = port 465, false = STARTTLS na 587)
SMTP_SECURE=false
