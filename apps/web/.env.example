# ============================================================
# Web (Next.js) — zmienne środowiskowe
# Skopiuj do .env.local i uzupełnij wartości
# NIE commituj .env.local do repozytorium
# ============================================================

# ── Backend API ──────────────────────────────────────────────
# URL backendu NestJS — używany do wywołań API i tRPC
# Produkcja: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:3001

# Ścieżka do Socket.IO na backendzie (domyślnie /socket.io)
NEXT_PUBLIC_SOCKET_PATH=/socket.io

# URL endpointu tRPC (backend URL + /trpc)
NEXT_PUBLIC_TRPC_URL=http://localhost:3001/trpc

# ── JWT — Middleware ─────────────────────────────────────────
# Sekret JWT — MUSI być identyczny jak JWT_SECRET w backendzie
# Używany przez Next.js middleware do walidacji access tokenów
# (min. 32 znaki — taki sam jak w apps/backend/.env)
JWT_SECRET=your-super-secret-key-minimum-32-characters-long

# ── PostHog Analytics ────────────────────────────────────────
# Klucz API PostHog (pobierz z Project Settings > Project API Key)
# https://app.posthog.com lub https://eu.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_here

# Host PostHog: https://app.posthog.com (US) lub https://eu.posthog.com (EU)
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
