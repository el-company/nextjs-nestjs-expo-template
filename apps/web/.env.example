NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_PATH=/socket.io
NEXT_PUBLIC_TRPC_URL=http://localhost:3001/trpc

# JWT Secret (for middleware token validation - should match backend)
JWT_SECRET=your-super-secret-key-minimum-32-characters-long

# PostHog Analytics
# Get your API key from PostHog (https://app.posthog.com or https://eu.posthog.com)
# Go to Project Settings > Project API Key
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_here
# Use https://app.posthog.com (US) or https://eu.posthog.com (EU) depending on your region
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
